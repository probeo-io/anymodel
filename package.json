{
  "name": "@probeo/anymodel",
  "version": "0.5.2",
  "description": "OpenRouter-compatible LLM router with unified batch support. Self-hosted, zero fees.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "anymodel": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "serve": "node dist/cli.js serve",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "router",
    "batch",
    "ai"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/probeo-io/anymodel"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "p-queue": "^9.1.0"
  }
}
